# Claude environment — machine-specific secrets and paths
# Populated by setup.sh — DO NOT commit this file with real values
# Copy to ~/.claude/env.sh and fill in the values

# LinkedIn OAuth credentials (generated by scripts/linkedin-oauth.sh)
export LINKEDIN_CLIENT_ID=""
export LINKEDIN_CLIENT_SECRET=""
export LINKEDIN_TOKEN=""
export LINKEDIN_PERSON_URN=""

# Webex OAuth credentials (for webex-update skill)
# Run scripts/webex-oauth.sh to populate — do not set WEBEX_TOKEN manually
export WEBEX_CLIENT_ID=""
export WEBEX_CLIENT_SECRET=""
export WEBEX_TOKEN=""
export WEBEX_REFRESH_TOKEN=""

# Splunk MCP server
# SPLUNK_HOST: IP or hostname only (no port), e.g. 10.66.121.3
# SPLUNK_TOKEN: encrypted MCP token from Splunk MCP Server app (Settings > MCP Tokens)
#               Note: this is NOT a regular Splunk API token — get it from the app UI
export SPLUNK_HOST=""
export SPLUNK_TOKEN=""

# Splunk REST API credentials (used by skills to deploy dashboards etc.)
# SPLUNK_USER / SPLUNK_PASS: a local Splunk admin account, OR
# SPLUNK_API_TOKEN: a native Splunk API token (Settings > Tokens in Splunk Web)
#                   If set, takes precedence over SPLUNK_USER/SPLUNK_PASS
export SPLUNK_USER=""
export SPLUNK_PASS=""
export SPLUNK_API_TOKEN=""

# GitHub fine-grained PAT (for GitHub MCP + branch protection)
# Required permissions: Contents (rw), Administration (rw), Workflows (rw), Metadata (r), Pull requests (rw)
# Account permissions: Email addresses (r)
# Generate at https://github.com/settings/personal-access-tokens/new
export GITHUB_TOKEN=""

# GitLab personal access token (for glab CLI + GitLab API access)
# Required scopes: api, read_user, read_repository
# Generate at: https://gitlab.com/-/user_settings/personal_access_tokens
export GITLAB_TOKEN=""

# Hugging Face API token (for local HF MCP server — enables dynamic_space invoke)
# Generate at: https://huggingface.co/settings/tokens
# Required scopes: Inference API (serverless), Read access to public gated repos
export HF_TOKEN=""
